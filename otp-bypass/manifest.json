{
  "manifest_version": 3,
  "name": "OTP Magic Link Bypass",
  "version": "1.0.0",
  "description": "Advanced OTP email interception and magic link bypass tool for email verification",
  "permissions": [
    "activeTab", 
    "storage", 
    "tabs", 
    "scripting",
    "contextMenus",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>", 
    "*://*.gmail.com/*", 
    "*://*.outlook.com/*", 
    "*://*.yahoo.com/*",
    "*://*.mail.com/*",
    "*://*.protonmail.com/*",
    "*://*.icloud.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png", 
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["*.png", "*.css"],
      "matches": ["<all_urls>"]
    }
  ]
}